---
import '../styles/navigation.css';
---

<header class="small--extra" id="top">
  <nav>
    <span><strong>Dan Arbello</strong><span> | Design | Engineering</span></span>
    <ul>
      <li><a class="standalone" href="/">Home</a></li>
      <li><a class="standalone" href="/fragments">Fragments</a></li>
      <li><a class="standalone" href="/dangents">Dangents</a></li>
      <li><a class="standalone" href="/resume">Resume</a></li>
    </ul>
  </nav>
</header>

<script>
  const currentPath = window.location.pathname;
  const links = document.querySelectorAll('header .standalone');
  links.forEach(link => {
    const href = link.getAttribute('href');
    if (currentPath === href || currentPath.startsWith(href + '/')) {
      link.classList.add('current');
    }
  });
</script>
